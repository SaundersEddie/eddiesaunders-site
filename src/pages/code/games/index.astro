---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/pages/code.css';

const gameProjects = [
  {
    title: 'eddiesgames.xyz',
    type: 'Playable browser games',
    status: 'Active',
    text: 'A growing collection of lightweight browser games with daily challenges, scoreboards, shareable results, and Cloudflare-backed APIs.',
    links: [
      {
        label: 'Play the Games',
        href: 'https://eddiesgames.xyz',
      },
      {
        label: 'Project Writeup',
        href: '/code/eddiesgames/',
      },
    ],
  },
  {
    title: 'One Grid at a Time',
    type: 'Game development series',
    status: 'Active',
    text: 'A practical series about building small, complete mobile games one project at a time, covering development, graphics, audio, testing, publishing, and everything that goes sideways along the way.',
    links: [
      {
        label: 'Explore OGaaT',
        href: '/code/games/ogaat/',
      },
    ],
  },
  {
    title: 'Diary of a Game',
    type: 'Development diary',
    status: 'Active',
    text: 'Longer-form development journals following individual games from early ideas and prototypes through systems, levels, testing, polish, and release.',
    links: [
      {
        label: 'Explore the Diary',
        href: '/code/games/diary/',
      },
      {
        label: 'Courier16',
        href: '/code/games/diary/courier16/',
      },
    ],
  },
];
---

<BaseLayout
  title='Games | Eddie Saunders'
  description='Playable browser games, game development projects, One Grid at a Time, and Diary of a Game by Eddie Saunders.'
>
  <section class='page-hero code-hero'>
    <p class='eyebrow'>Code / Games</p>
    <h1>Games</h1>
    <p>
      Playable games, active development projects, and honest development
      journals covering what worked, what broke, and what had to be rebuilt.
    </p>
  </section>

  <section class='project-showcase'>
    <div class='project-showcase-heading'>
      <p class='eyebrow'>Game development</p>
      <h2>Play the games. Follow the builds.</h2>
      <p>
        Browser games, mobile projects, and longer development diaries, kept
        together without turning the page into a filing system from hell.
      </p>
    </div>

    <div class='project-grid'>
      {
        gameProjects.map((item) => (
          <article class='project-card'>
            <p class='project-type'>{item.type}</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>

            <div class='project-links'>
              {item.links.map((link) => (
                <a
                  href={link.href}
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>

            <span>{item.status}</span>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
