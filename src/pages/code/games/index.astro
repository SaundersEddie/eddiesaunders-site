---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/pages/code.css';

const featuredProjects = [
  {
    title: 'eddiesgames.xyz',
    type: 'Playable browser games',
    status: 'Active',
    text: 'Small browser games, daily scoreboards, shareable results, and lightweight Cloudflare-backed APIs.',
    links: [
      {
        label: 'Live Site',
        href: 'https://eddiesgames.xyz',
      },
      {
        label: 'Project Writeup',
        href: '/code/eddiesgames/',
      },
    ],
  },
  {
    title: 'One Grid at a Time',
    type: 'Game development series',
    status: 'Launching July 19',
    text: 'Building practical games one manageable system at a time, covering code, graphics, audio, mobile development, testing, publishing, and everything that breaks along the way.',
    links: [
      {
        label: 'Explore OGaaT',
        href: '/code/games/ogaat/',
      },
    ],
  },
];

const currentProjects = [
  {
    title: 'Courier16',
    type: 'Unity game project',
    status: 'In progress',
    text: 'A compact side-scrolling delivery platformer following the full development process from early prototype through levels, polish, WebGL, and release.',
    links: [
      {
        label: 'Repo',
        href: 'https://github.com/SaundersEddie/courier16',
      },
      {
        label: 'Diary of a Game',
        href: '/code/games/diary/courier16/',
      },
    ],
  },
];

const gameLabs = [
  {
    title: 'Sudoku Development',
    type: 'Puzzle logic / Unity',
    status: 'Active lab',
    text: 'Sudoku generation, solving, validation, testing, responsive interfaces, and the lessons learned while taking the same puzzle system from Python into Unity.',
    links: [
      {
        label: 'Python Repo',
        href: 'https://github.com/SaundersEddie/python-sudoku',
      },
      {
        label: 'Unity Repo',
        href: 'https://github.com/SaundersEddie/unity-sudoku',
      },
    ],
  },
  {
    title: 'Audio Converter',
    type: 'Game dev tool',
    status: 'Active',
    text: 'A small Python and FFmpeg helper for converting game audio assets into the formats I actually need, including MP3, WAV, OGG, M4A, AAC, and FLAC.',
    links: [
      {
        label: 'Repo',
        href: 'https://github.com/SaundersEddie/audio-convert',
      },
    ],
  },
];
---

<BaseLayout
  title='Games | Eddie Saunders'
  description='Playable browser games, Unity projects, development tools, and One Grid at a Time by Eddie Saunders.'
>
  <section class='page-hero code-hero'>
    <p class='eyebrow'>Code / Games</p>
    <h1>Games</h1>
    <p>
      Playable games, active development projects, practical tools, and One Grid
      at a Time — building games without pretending everything worked on the
      first attempt.
    </p>
  </section>

  <section class='project-showcase'>
    <div class='project-showcase-heading'>
      <p class='eyebrow'>Games and development</p>
      <h2>Play the games. Follow the builds.</h2>
      <p>
        The main game site and the development series covering how the projects
        are designed, built, tested, broken, fixed, and eventually released.
      </p>
    </div>

    <div class='project-grid'>
      {
        featuredProjects.map((item) => (
          <article class='project-card'>
            <p class='project-type'>{item.type}</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>

            {item.links && (
              <div class='project-links'>
                {item.links.map((link) => (
                  <a
                    href={link.href}
                    target={link.href.startsWith('http') ? '_blank' : undefined}
                    rel={
                      link.href.startsWith('http') ? 'noreferrer' : undefined
                    }
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            )}

            <span>{item.status}</span>
          </article>
        ))
      }
    </div>
  </section>

  <section class='project-showcase'>
    <div class='project-showcase-heading'>
      <p class='eyebrow'>Current game project</p>
      <h2>Courier16</h2>
      <p>
        The active Unity project, with its repository and original Diary of a
        Game development journal kept together in one place.
      </p>
    </div>

    <div class='project-grid'>
      {
        currentProjects.map((item) => (
          <article class='project-card'>
            <p class='project-type'>{item.type}</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>

            <div class='project-links'>
              {item.links.map((link) => (
                <a
                  href={link.href}
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>

            <span>{item.status}</span>
          </article>
        ))
      }
    </div>
  </section>

  <section class='project-showcase'>
    <div class='project-showcase-heading'>
      <p class='eyebrow'>Game dev labs</p>
      <h2>Logic, tools, and experiments</h2>
      <p>
        Smaller projects focused on solving practical development problems,
        including generation, validation, testing, asset preparation, input,
        layout, and platform builds.
      </p>
    </div>

    <div class='project-grid'>
      {
        gameLabs.map((item) => (
          <article class='project-card'>
            <p class='project-type'>{item.type}</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>

            <div class='project-links'>
              {item.links.map((link) => (
                <a
                  href={link.href}
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>

            <span>{item.status}</span>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
