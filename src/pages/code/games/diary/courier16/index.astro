const getEntryId = (entry: DiaryEntry) => `chapter-${entry.chapter}`;

const latestEntry = courierEntries[courierEntries.length - 1];
const indexedEntries = [...courierEntries].reverse();
---

<BaseLayout
  title='Courier 16 Diary | Eddie Saunders'
  description='Build diary for Courier 16, a game development project by Eddie Saunders.'
>
  <section class='page-hero code-hero'>
    <p class='eyebrow'>Diary of a Game</p>
    <h1>Courier 16</h1>
    <p>
      A compact Unity side-scrolling delivery platformer about getting the
      package to the end of each route. This diary follows the project from
      early concept through prototype, level design, polish, WebGL build, and
      release.
    </p>
  </section>

  <section class='project-showcase'>
    <div class='project-showcase-heading'>
      <p class='eyebrow'>Quick index</p>
      <h2>Latest and past entries</h2>
      <p>
        Jump straight to the newest Courier 16 update or browse the diary by
        chapter.
      </p>
    </div>

    <div class='project-grid'>
      <article class='project-card'>
        <p class='project-type'>Latest entry</p>
        <h3>
          Chapter {latestEntry.chapter}: {latestEntry.title}
        </h3>
        <p>
          {latestEntry.date}
          <br />
          {latestEntry.stage}
        </p>

        <div class='project-links'>
          <a href={`#${getEntryId(latestEntry)}`}>Read Latest</a>
        </div>

        <span>{latestEntry.focus}</span>
      </article>

      <article class='project-card'>
        <p class='project-type'>Entry index</p>
        <h3>Courier 16 chapters</h3>

        <div class='diary-index-list'>
          {
            indexedEntries.map((entry) => (
              <a href={`#${getEntryId(entry)}`}>
                <span>
                  {entry.date} · Chapter {entry.chapter}
                </span>
                <strong>{entry.title}</strong>
              </a>
            ))
          }
        </div>
      </article>
    </div>
  </section>

  <section class='development-log'>
    <header class='development-log__header'>
      <p class='eyebrow'>Development log</p>
      <h2>Building Courier 16</h2>
      <p>
        These chapters follow Courier 16 from rough idea to playable release.
        Each one focuses on a decision, problem, milestone, or lesson from the
        build rather than acting as a raw changelog.
      </p>
    </header>

    <div class='diary-timeline'>
      {
        courierEntries.map((entry) => (
          <article class='diary-entry' id={getEntryId(entry)}>
            <header class='diary-entry__header'>
              <div class='diary-entry__meta-row'>
                <span>{entry.date}</span>
                <span>{entry.stage}</span>
              </div>

              <h3>
                <span>Chapter {entry.chapter}</span>
                {entry.title}
              </h3>

              <p class='diary-entry__focus'>
                <strong>Focus:</strong> {entry.focus}
              </p>
            </header>

            <div class='diary-entry__body'>
              {entry.blocks.map((block) => {
                if (block.type === 'paragraph') {
                  return (
                    <p>
                      {block.content.map((part) => {
                        if (part.href) {
                          return (
                            <a
                              href={part.href}
                              target='_blank'
                              rel='noopener noreferrer'
                            >
                              {part.strong ? (
                                <strong>{part.text}</strong>
                              ) : (
                                part.text
                              )}
                            </a>
                          );
                        }

                        if (part.strong) return <strong>{part.text}</strong>;
                        if (part.em) return <em>{part.text}</em>;
                        if (part.code) return <code>{part.text}</code>;

                        return part.text;
                      })}
                    </p>
                  );
                }

                if (block.type === 'pullquote') {
                  return (
                    <aside class='diary-pullquote'>
                      <p>{block.text}</p>
                    </aside>
                  );
                }

                if (block.type === 'figure') {
                  return (
                    <figure class='diary-figure'>
                      <img src={block.src} alt={block.alt} />
                      <figcaption>{block.caption}</figcaption>
                    </figure>
                  );
                }

                if (block.type === 'note') {
                  return (
                    <aside class='diary-note'>
                      <p class='diary-note__label'>Build note</p>
                      <h4>{block.title}</h4>
                      <p>{block.text}</p>
                    </aside>
                  );
                }

                if (block.type === 'next') {
                  return (
                    <aside class='next-step'>
                      <p class='next-step__label'>Next</p>
                      <h4>{block.title}</h4>
                      <p>{block.text}</p>
                    </aside>
                  );
                }

                return null;
              })}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
