---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/pages/code.css';

const codeAreas = [
  {
    title: 'Games',
    href: '/code/games/',
    text: 'Game development, playable projects, experiments, and development diaries from Diary of a Game and One Grid at a Time.',
  },
  {
    title: 'Beyond Games',
    href: '/code/beyondgames/',
    text: 'Utilities, websites, automation, AI experiments, testing tools, and practical software—including the audio conversion tool.',
  },
];
---

<BaseLayout
  title='Code | Eddie Saunders'
  description='Game and non-game software projects, tools, experiments, and development work by Eddie Saunders.'
>
  <section class='page-hero code-hero'>
    <p class='eyebrow'>Code</p>
    <h1>Useful Code</h1>
    <p>
      Game projects and practical non-game software, kept simple and organized
      by what the code is actually for.
    </p>
  </section>

  <section class='content-grid code-area-grid' aria-label='Code project areas'>
    {
      codeAreas.map((item) => (
        <a class='content-card code-area-card' href={item.href}>
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </a>
      ))
    }
  </section>
</BaseLayout>
