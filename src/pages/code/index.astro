---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/pages/code.css";

const featuredProjects = [
  {
    title: "eddiesaunders.com Rebuild",
    type: "Web Projects",
    status: "In progress",
    href: "",
    links: [
      {
        label: "Current Site",
        href: "/",
      },
    ],
    text: "A full personal-site rebuild using Astro, with a cleaner structure, sharper portfolio pages, and a move away from GoDaddy toward Cloudflare Pages.",
  },
  {
    title: "Image Background Remover",
    type: "Small Tools",
    status: "In progress",
    href: "",
    text: "A local desktop tool concept for turning images into transparent-background PNGs, with future GUI and SVG workflow ideas.",
  },
  {
    title: "eddiesgames.xyz",
    type: "Games",
    status: "Active",
    href: "",
    links: [
      {
        label: "Live Site",
        href: "https://eddiesgames.xyz",
      },
      {
        label: "Project Writeup",
        href: "/code/eddiesgames/",
      },
    ],
    text: "Small browser games with daily scoreboards, shareable results, and lightweight Cloudflare-backed APIs. Built as both a playable game site and an ongoing web/game development lab.",
  },
  {
    title: "WMATA Incident Summarizer",
    type: "AI Experiments",
    status: "Prototype",
    href: "",
    links: [
      {
        label: "Backend Repo",
        href: "https://github.com/SaundersEddie/wmata-be",
      },
      {
        label: "Frontend Repo",
        href: "https://github.com/SaundersEddie/wmata-fe",
      },
    ],
    text: "A split frontend/backend experiment for turning WMATA transit incident data into cleaner human-readable summaries.",
  },
];

const codeAreas = [
  {
    title: "Web projects",
    href: "/code/web-projects/",
    text: "Astro sites, browser games, static builds, deployment experiments, and practical web work that stays lean.",
  },
  {
    title: "Small tools",
    href: "/code/small-tools/",
    text: "Python utilities, automation helpers, image tools, scripts, and projects built to solve real annoyances.",
  },
  {
    title: "Games",
    href: "/code/games/",
    text: "Small browser games, Unity prototypes, C64-style learning builds, scoreboards, and gameplay experiments.",
  },
  {
    title: "AI experiments",
    href: "/code/ai-experiments/",
    text: "Carefully scoped AI helpers, summarizers, content tools, and experiments that earn their keep instead of waving jazz hands.",
  },
];

---

<BaseLayout
  title="Code | Eddie Saunders"
  description="Code projects, web experiments, games, tools, automation, and AI experiments by Eddie Saunders."
>
  <section class="page-hero code-hero">
    <p class="eyebrow">Code</p>
    <h1>Useful Code</h1>
    <p>
      Web projects, small tools, games, automation experiments, and practical
      code built to solve a problem, test an idea, or make the next job easier.
    </p>
  </section>

  <section class="content-grid code-area-grid" aria-label="Code project areas">
    {codeAreas.map((item) => (
      <a class="content-card code-area-card" href={item.href}>
        <h2>{item.title}</h2>
        <p>{item.text}</p>
      </a>
    ))}
  </section>

  <section class="project-showcase">
    <div class="project-showcase-heading">
      <p class="eyebrow">Featured projects</p>
      <h2>Useful little machines</h2>
      <p>
        A mix of live sites, small tools, experiments, game projects, and practical
        code built to solve real problems or test useful ideas.
      </p>
    </div>

    <div class="project-grid">
      {featuredProjects.map((item) => {
        const CardTag = item.href ? "a" : "article";

        return (
          <CardTag
            class="project-card"
            href={item.href || undefined}
            target={item.href ? "_blank" : undefined}
            rel={item.href ? "noreferrer" : undefined}
          >
            <p class="project-type">{item.type}</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>

            {item.links && (
              <div class="project-links">
                {item.links.map((link) => (
                  <a href={link.href} target="_blank" rel="noreferrer">
                    {link.label}
                  </a>
                ))}
              </div>
            )}

            <span>{item.status}</span>
          </CardTag>
        );
      })}
    </div>
  </section>
</BaseLayout>
