---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/pages/code.css";

const featuredTools = [
  {
    title: "Image Background Remover",
    type: "Featured tool",
    status: "In progress",
    text: "A local desktop tool concept for turning images into transparent-background PNGs, with future GUI and SVG workflow ideas.",
  },
];

const pythonTools = [
  {
    title: "Python Sudoku Generator",
    type: "Python / Testing",
    status: "Active",
    text: "A puzzle generation, validation, and test pipeline for creating reliable Sudoku boards.",
    links: [
      {
        label: "Repo",
        href: "https://github.com/SaundersEddie/python-sudoku",
      },
    ],
  },
  {
    title: "Eddie's Content Tools",
    type: "Python / Facebook drafting tool",
    status: "Active",
    text: "A local Python tool for creating sourced Facebook draft posts from date-based historical, music, film, science, literature, and technology events. It saves seed data, generates a raw draft, polishes the copy with OpenAI, and outputs a clean copy/paste file with sources.",
    links: [
      {
        label: "Repo",
        href: "https://github.com/SaundersEddie/eddies-content-tools",
      },
    ],
  },
  {
    title: "Weather Summary Tool",
    type: "Python / Data tool",
    status: "Prototype",
    text: "A small Open-Meteo processing project for turning weather data into readable daily summaries.",
    links: [
      {
        label: "Repo",
        href: "https://github.com/SaundersEddie/weather-spa",
      },
    ],
  },
  {
    title: "WMATA Processor",
    type: "Python / API tool",
    status: "Prototype",
    text: "Backend logic for fetching WMATA incident data, processing relevant fields, and preparing cleaner summaries.",
    links: [
      {
        label: "Backend Repo",
        href: "https://github.com/SaundersEddie/wmata-be",
      },
    ],
  },
];

const automationHelpers = [
  {
    title: "Sudoku Batch Tests",
    type: "Testing helper",
    status: "Active",
    text: "Batch scripts for stress-testing generated Sudoku boards and checking puzzle reliability over large runs.",
  },
  {
    title: "Playwright Demo Tooling",
    type: "Testing / Automation",
    status: "In progress",
    text: "Small demo projects and test suites for showing browser automation, UI checks, and practical testing workflows.",
  },
  {
    title: "Workflow Scripts",
    type: "Automation",
    status: "Planned",
    text: "Small scripts for repeatable project tasks, cleanup passes, and workflow shortcuts that save future headaches.",
  },
];

const plannedTools = [
  {
    title: "Etsy Listing Helpers",
    type: "Planned tool",
    status: "Planned",
    text: "Helpers for turning product details into cleaner listing descriptions, tags, and shop copy.",
  },
  {
    title: "Product Costing Helpers",
    type: "Planned tool",
    status: "Planned",
    text: "Simple tools for estimating material, print time, failure rate, bundle sizing, and pricing decisions.",
  },
  {
    title: "Image / Content Review Helpers",
    type: "Planned tool",
    status: "Planned",
    text: "Future moderation-style helpers for checking uploaded images or custom requests before they become production problems.",
  },
];
---

<BaseLayout
  title="QA & Small Tools | Eddie Saunders"
  description="Testing helpers, Python utilities, automation scripts, and practical workflow tools by Eddie Saunders."
>
  <section class="page-hero code-hero">
    <p class="eyebrow">Code / QA & Small Tools</p>
    <h1>QA & Small Tools</h1>
    <p>
      Testing helpers, Python utilities, automation scripts, content tools, and
      small projects built because some annoying job needed to be less annoying.
    </p>
  </section>

  <section class="project-showcase">
    <div class="project-showcase-heading">
      <p class="eyebrow">Featured tool</p>
      <h2>Useful first, flashy second</h2>
      <p>
        Small tools are where the boring wins live: cleaner files, faster testing,
        repeatable workflows, and fewer manual chores.
      </p>
    </div>

    <div class="project-grid">
      {featuredTools.map((item) => (
        <article class="project-card">
          <p class="project-type">{item.type}</p>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <span>{item.status}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="project-showcase">
    <div class="project-showcase-heading">
      <p class="eyebrow">Python utilities</p>
      <h2>Scripts, processors, and useful logic</h2>
      <p>
        Python projects that handle the behind-the-scenes work: data processing,
        validation, testing, summaries, content drafting, and repeatable utility
        workflows.
      </p>
    </div>

    <div class="project-grid">
      {pythonTools.map((item) => (
        <article class="project-card">
          <p class="project-type">{item.type}</p>
          <h3>{item.title}</h3>
          <p>{item.text}</p>

          {item.links && (
            <div class="project-links">
              {item.links.map((link) => (
                <a
                  href={link.href}
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noreferrer" : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>
          )}

          <span>{item.status}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="project-showcase">
    <div class="project-showcase-heading">
      <p class="eyebrow">Testing and automation helpers</p>
      <h2>Little scripts that keep projects honest</h2>
      <p>
        Testing tools, automation helpers, and workflow scripts that make it
        easier to check work instead of guessing and hoping. Very scientific.
      </p>
    </div>

    <div class="project-grid">
      {automationHelpers.map((item) => (
        <article class="project-card">
          <p class="project-type">{item.type}</p>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <span>{item.status}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="project-showcase">
    <div class="project-showcase-heading">
      <p class="eyebrow">Planned tools</p>
      <h2>Ideas worth building later</h2>
      <p>
        Not every useful tool needs to exist today. These are the likely next
        candidates once the main site structure stops demanding snacks and attention.
      </p>
    </div>

    <div class="project-grid">
      {plannedTools.map((item) => (
        <article class="project-card">
          <p class="project-type">{item.type}</p>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <span>{item.status}</span>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
