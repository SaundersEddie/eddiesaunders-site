---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/pages/creations.css";

const latestProjects = [
  {
    id: "cnc-cedar-card-suit-snack-tray",
    title: "CNC Cedar Card Suit Snack Tray",
    category: "CNC / Woodworking",
    material: "Live edge cedar and walnut",
    machine: "OneFinity Journeyman X50",
    status: "In progress",
    finish: "Poly on the cedar tray, Odie’s Oil on the walnut bowls",
    description:
      "A live-edge cedar snack tray with walnut card suit bowls, designed for card players, snack people, and anyone who appreciates useful wood nonsense.",
    uses: [
      "Snack tray",
      "Card table tray",
      "Etsy product test",
      "CNC finish experiment",
    ],
    images: [
      {
        src: "/images/creations/cnc-woodworking/card-suit-board-before.JPG",
        alt: "CNC carved card suit tray before final finishing",
        caption:
          "The tray before final finish, with the walnut card suit bowls sitting proud against the live-edge cedar.",
      },
      {
        src: "/images/creations/cnc-woodworking/card-suit-board-after.JPG",
        alt: "CNC carved card suit tray after finish has been applied",
        caption:
          "After finish, the cedar color deepens and the card suits blend more naturally into the board.",
      },
    ],
  },
];

const archivedProjects = [
  {
    id: "hand-turned-pens",
    title: "Hand-Turned Wood and Resin Pens",
    category: "Woodturning / Pen Making",
    material:
      "Commercial wood blanks, handmade resin blanks, recovered wood, and wood-resin combinations",
    machine: "Wood lathe",
    status: "Archived — may return in fall",
    description:
      "A collection of individually turned pens made from wood, resin, recovered timber, and mixed-material blanks.",
    content: [
      "I have made pens from commercial wood blanks, blanks prepared from my own timber, resin blanks that I poured myself, and combinations of recovered wood and resin. Every pen was shaped, sanded, finished, and assembled individually on my lathe.",
      "Some were built around fairly simple hardware, while others used heavily themed kits with decorative clips, caps, and finishes. The range of materials and components meant that even pens made from the same basic kit rarely came out looking identical.",
      "One of my favourites is the dog-paw pen. It was my first successful mixed-material turning, combining recovered wood with resin in the same blank. The wood came from a tree that broke at my daughter’s apartment complex, giving the finished pen a better story than anything bought ready-made.",
      "Pen turning is currently archived as both a workshop project and a product line, but it may return in the fall when cooler weather makes longer lathe sessions considerably less ridiculous.",
    ],
    images: [
      {
        src: "/images/creations/cnc-woodworking/pens/PenBox1.jpg",
        alt: "Collection of hand-turned wooden and resin pens displayed in a pen case",
        caption:
          "A selection of pens made from commercial blanks, prepared wood, resin, and mixed materials.",
      },
      {
        src: "/images/creations/cnc-woodworking/pens/PenBox2.jpg",
        alt: "Second collection of decorative hand-turned pens displayed in a pen case",
        caption:
          "Different kits, finishes, materials, and hardware gave each pen its own character.",
      },
      {
        src: "/images/creations/cnc-woodworking/pens/Pen6.jpg",
        alt: "Hand-turned dog paw pen made from recovered wood and resin",
        caption:
          "The dog-paw pen was my first successful combination of recovered wood and resin in a single turned blank.",
      },
      {
        src: "/images/creations/cnc-woodworking/pens/Pen.jpg",
        alt: "Green hand-poured resin pen turned on a wood lathe",
        caption:
          "A pen turned from one of my own resin pours, showing how much variation can come from a single blank. This was donated to a young man just starting his journalism career.",
      },
    ],
  },
  {
  id: "salvaged-live-edge-bowl",
  title: "Salvaged Live-Edge Bowl",
  category: "Woodturning / Bowl Making",
  material: "Unknown salvaged hardwood",
  machine: "Wood lathe",
  status: "Archived",
  description:
    "A live-edge bowl turned from an unidentified lump of hardwood rescued from a trash pile outside a local wood supplier.",
  content: [
    "This bowl started as a random lump of hardwood found in a trash pile outside a local wood supplier. I never identified the species, but the blank had enough interesting grain and natural edge left to make it worth dragging home.",
    "Rather than forcing it into a perfectly round and uniform bowl, I kept part of the original outside edge around the rim. That gave the finished piece an uneven live-edge profile and preserved some of the character that made the discarded wood interesting in the first place.",
    "The bowl was shaped, hollowed, sanded, and finished on the lathe. The unknown wood turned cleanly and revealed strong growth rings, colour variation, and a knot near the centre that became part of the finished design.",
    "It is a good example of why apparently useless wood is rarely useless until someone has actually tried making something from it.",
  ],
  images: [
    {
      src: "/images/creations/cnc-woodworking/bowls/Bowl3.jpg",
      alt: "Finished live-edge bowl turned from salvaged hardwood",
      caption:
        "The finished bowl, with the natural edge and grain left to provide most of the decoration.",
    },
    {
      src: "/images/creations/cnc-woodworking/bowls/Bowl4.jpg",
      alt: "Live-edge hardwood bowl mounted on a wood lathe",
      caption:
        "The bowl still mounted on the lathe, showing the uneven natural rim and the hollowed interior.",
    },
    {
      src: "/images/creations/cnc-woodworking/bowls/Bowl5.jpg",
      alt: "Second view of the finished salvaged hardwood bowl",
      caption:
        "Another finished view showing the grain, knot, and irregular live-edge profile.",
    },
  ],
},
{
  id: "cnc-gift-boxes",
  title: "CNC Gift Boxes from Workshop Offcuts",
  category: "CNC / Box Making",
  material:
    "Workshop offcuts, reclaimed walnut, reclaimed cedar, decorative hardware, and felt lining",
  machine: "OneFinity Journeyman X50",
  status: "Archived",
  description:
    "A collection of CNC-machined gift boxes made from workshop offcuts and given to friends and family.",
  content: [
    "These boxes were among my first experiments with making fitted containers on the CNC. They were made from offcuts already in the workshop rather than timber bought specifically for the projects, which meant each box developed around the material that was available.",
    "The projects also gave me room to experiment with contrasting woods, engraved lids, decorative hardware, turned components, and different box shapes. One handle was turned from reclaimed walnut, while reclaimed cedar was used for the contrasting cap set into the top.",
    "The interiors were my first real attempt at finishing the inside of a box. At the time, I had not yet discovered flocking, so I cut and glued felt into the compartments by hand. It worked, but the edges and joins were far less tidy than I would accept now.",
    "Flocking uses short fibres applied over an adhesive-coated surface, usually with an applicator that helps the fibres stand upright. It creates a soft, seamless interior finish without the visible cuts, overlaps, and awkward corners that come with fitting sheets of felt.",
    "These boxes were all given away to friends and family. They are not current products, but they are useful archive pieces because they show an early stage of learning CNC box construction, interior finishing, hardware placement, and how much difference the final details make.",
  ],
  images: [
    {
      src: "/images/creations/cnc-woodworking/gift-boxes/Box1.jpg",
      alt: "Round CNC-machined wooden box with carved tropical design and turned walnut handle",
      caption:
        "A round machined box with a carved lid, turned reclaimed-walnut handle, and contrasting reclaimed-cedar cap.",
    },
    {
      src: "/images/creations/cnc-woodworking/gift-boxes/Box2.jpg",
      alt: "Turned walnut box handle with contrasting reclaimed cedar insert",
      caption:
        "The handle was turned from reclaimed walnut, with the contrasting cap cut precisely from reclaimed cedar.",
    },
    {
      src: "/images/creations/cnc-woodworking/gift-boxes/DiceBox2.jpg",
      alt: "Two-tone rectangular wooden gift box with decorative antique-style hardware",
      caption:
        "A two-tone gift box made from offcuts and finished with decorative hinges, feet, corner protectors, and a latch.",
    },
    {
      src: "/images/creations/cnc-woodworking/gift-boxes/DiceBox3.jpg",
      alt: "Open rectangular wooden gift box with black felt-lined interior",
      caption:
        "The hand-fitted felt interior was an early attempt at lining a box before I knew about flocking.",
    },
    {
      src: "/images/creations/cnc-woodworking/gift-boxes/ToriBox1.jpg",
      alt: "Oval CNC-machined wooden box lid engraved with the name Victoria",
      caption:
        "A personalized oval lid engraved on the CNC for a family gift.",
    },
    {
      src: "/images/creations/cnc-woodworking/gift-boxes/ToriBox2.jpg",
      alt: "Oval wooden gift box with hand-fitted black felt interior",
      caption:
        "Another early felt-lined interior, showing both the progress and the limitations of fitting sheet material by hand.",
    },
  ],
},
];

const archiveProjects = [...latestProjects, ...archivedProjects];
---

<BaseLayout
  title="CNC & Woodworking | Eddie Saunders"
  description="CNC and woodworking projects, handmade products, market pieces, Etsy items, and custom creations."
>
  <section class="page-hero creations-hero">
    <p class="eyebrow">Creations</p>

    <h1>CNC & Woodworking</h1>

    <p>
      CNC-cut pieces, handmade goods, shop experiments, market products, Etsy
      ideas, and whatever happens when wood, tools, and questionable confidence
      meet in the same room.
    </p>
  </section>

  <section
    class="creations-latest-section"
    aria-labelledby="latest-cnc-heading"
  >
    <div class="section-content">
      <div class="section-header">
        <p class="eyebrow">Latest</p>

        <h2 id="latest-cnc-heading">Latest CNC & Woodworking Project</h2>

        <p>
          Current builds, finish tests, market pieces, and useful woodworking
          ideas as they move from rough stock to finished item.
        </p>
      </div>

      <div class="print-design-list">
        {
          latestProjects.map((project) => (
            <article
              id={project.id}
              class="print-design-card project-article"
            >
              <div class="print-design-content">
                <p class="creation-card-category">{project.category}</p>

                <h3>{project.title}</h3>

                <p class="print-design-summary">{project.description}</p>

                <div class="print-design-meta" aria-label="Project details">
                  <span>Material: {project.material}</span>
                  <span>Machine: {project.machine}</span>
                  <span>Status: {project.status}</span>
                </div>

                <p>
                  This project started with a live-edge cedar board I picked up
                  cheap from a vendor in Wilmington, NC, and some walnut offcuts
                  I already had hanging around the shop.
                </p>

                <p>
                  The idea was simple enough: use the cedar as the tray body,
                  carve the playing card suits, and make walnut bowls for the
                  inserts. It felt like a good fit for card players, game
                  nights, snack tables, or anyone who wants something a little
                  more interesting than another plain tray.
                </p>

                <p>
                  The tray was cut on the OneFinity Journeyman X50, which is
                  very much the big boy machine for this kind of work. The cedar
                  tray gets a poly finish, while the walnut bowls get Odie’s Oil
                  to bring out the darker grain.
                </p>

                <p>
                  This one is still in progress and waiting on final finish
                  before I decide whether it heads to Etsy. So far, it is doing
                  exactly what a good prototype should do: showing what works,
                  what needs cleaning up, and whether the idea has legs.
                </p>

                <p>Finish note: {project.finish}.</p>

                <div class="print-use-list" aria-label="Project uses">
                  {
                    project.uses.map((use) => (
                      <span>{use}</span>
                    ))
                  }
                </div>
              </div>

              <div class="print-design-images">
                {
                  project.images.map((image) => (
                    <figure class="print-design-image creation-wide-image">
                      <img
                        src={image.src}
                        alt={image.alt}
                        loading="lazy"
                      />

                      <figcaption>{image.caption}</figcaption>
                    </figure>
                  ))
                }
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="creations-archive-section"
    aria-labelledby="cnc-archive-heading"
  >
    <div class="section-content">
      <div class="section-header">
        <p class="eyebrow">Archive</p>

        <h2 id="cnc-archive-heading">CNC & Woodworking Project Archive</h2>

        <p>
          Jump directly to a project below. New and older work will all remain
          available here as the archive grows.
        </p>
      </div>

      <nav
        class="project-archive-list"
        aria-label="CNC and woodworking project archive"
      >
        {
          archiveProjects.map((project) => (
            <a href={`#${project.id}`}>{project.title}</a>
          ))
        }
      </nav>

      <div class="print-design-list">
        {
          archivedProjects.map((project) => (
            <article
              id={project.id}
              class="print-design-card project-article"
            >
              <div class="print-design-content">
                <p class="creation-card-category">{project.category}</p>

                <h3>{project.title}</h3>

                <p class="print-design-summary">{project.description}</p>

                <div class="print-design-meta" aria-label="Project details">
                  <span>Material: {project.material}</span>
                  <span>Machine: {project.machine}</span>
                  <span>Status: {project.status}</span>
                </div>

                {
                  project.content.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))
                }
              </div>

              <div class="print-design-images">
                {
                  project.images.map((image) => (
                    <figure class="print-design-image creation-wide-image">
                      <img
                        src={image.src}
                        alt={image.alt}
                        loading="lazy"
                      />

                      <figcaption>{image.caption}</figcaption>
                    </figure>
                  ))
                }
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>