---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/pages/creations.css";

const creationAreas = [
  {
    title: "CNC & Woodwork",
    href: "/creations/cnc-woodwork/",
    text: "Cedar builds, trays, feeders, CNC tests, carved projects, guitar experiments, fixtures, finishes, and workshop lessons.",
  },
  {
    title: "3D Printing",
    href: "/creations/3d-printing/",
    text: "Useful prints, custom tags, fixtures, signs, prototypes, product tests, and small-batch items made across the printer fleet.",
  },
  {
    title: "Laser Work",
    href: "/creations/laser/",
    text: "Cut boxes, engraved pieces, slate tests, signs, templates, and production ideas that need clean lines and repeatable results.",
  },
  {
    title: "Build Diaries",
    href: "/creations/diaries/",
    text: "Workshop notes, project writeups, build progress, mistakes, fixes, material tests, and the stories behind the finished pieces.",
  },
  {
    title: "Brindle Besties",
    href: "",
    text: "The craft side of the operation: handmade goods, market pieces, Etsy items, custom products, and practical things made to sell.",
  },
  {
    title: "Custom Work",
    href: "",
    text: "A future home for custom requests, limited runs, commission notes, available pieces, and what kinds of projects make sense.",
  },
];
---

<BaseLayout
  title="Creations | Eddie Saunders"
  description="Woodwork, 3D prints, laser projects, CNC experiments, and handmade creations by Eddie Saunders."
>
  <section class="page-hero creations-hero">
    <p class="eyebrow">Workshop</p>
    <h1>My Creations</h1>
    <p>
      Woodwork, 3D prints, laser projects, CNC experiments, numbered handmade
      pieces, and the occasional idea that probably should have stayed in the
      notebook but somehow made it to the bench.
    </p>
  </section>

<section class="content-grid creations-area-grid" aria-label="Creation areas">
  {creationAreas.map((item) => {
    const CardTag = item.href ? "a" : "article";

    return (
      <CardTag class="content-card creations-area-card" href={item.href || undefined}>
        <h2>{item.title}</h2>
        <p>{item.text}</p>
      </CardTag>
    );
  })}
</section>

</BaseLayout>