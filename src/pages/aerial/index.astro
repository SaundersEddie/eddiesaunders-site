---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/pages/aerial.css";

const aerialAreas = [
  {
    title: "Part 107 Study",
    text: "Notes from learning the rules, charts, weather, airspace, procedures, and all the little FAA-flavored details that come with flying legally.",
  },
  {
    title: "Drone Practice",
    text: "Flight practice, camera work, shot planning, small tests, lessons learned, and building safe habits before doing anything serious.",
  },
  {
    title: "Views From Above",
    text: "Plane-window shots, tall-building views, overlook photos, drone images, and anything that makes the world look better from higher up.",
  },
  {
    title: "Aerial Ideas",
    text: "Potential video projects, small-town flythrough concepts, location notes, route planning, shot lists, and future aerial storytelling ideas.",
  },
];

const noteItems = [
  {
    title: "Study Log",
    text: "A future place for Part 107 study progress, tricky topics, reminders, and useful resources.",
  },
  {
    title: "Practice Notes",
    text: "Flight sessions, weather observations, camera settings, battery notes, and what to improve next time.",
  },
  {
    title: "Location Ideas",
    text: "Interesting places, elevated viewpoints, historic towns, scenic routes, and safe/legal flight planning ideas.",
  },
];
---

<BaseLayout
  title="Aerial Notes | Eddie Saunders"
  description="Aerial notes, Part 107 study, drone practice, elevated views, photography ideas, and flight observations by Eddie Saunders."
>
  <section class="page-hero aerial-hero">
    <p class="eyebrow">Flight / Views / Drone Study</p>
    <h1>Aerial Notes</h1>
    <p>
      Drone study, elevated views, airspace notes, aerial photography ideas,
      flight observations, and the process of learning to work safely and legally
      from above.
    </p>
  </section>

  <section class="content-grid">
    {aerialAreas.map((item) => (
      <article class="content-card">
        <h2>{item.title}</h2>
        <p>{item.text}</p>
      </article>
    ))}
  </section>

  <section class="aerial-panel">
    <div class="aerial-panel-copy">
      <p class="eyebrow">In progress</p>
      <h2>Learning the sky properly</h2>
      <p>
        This section can grow into a mix of Part 107 study notes, drone practice
        logs, elevated photography, location scouting, aerial video ideas, and
        anything else that starts with looking at the world from a better angle.
      </p>
    </div>

    <div class="aerial-note-list">
      {noteItems.map((item) => (
        <article>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
