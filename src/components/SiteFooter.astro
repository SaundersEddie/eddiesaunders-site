---
type IconName = "email" | "linkedin" | "facebook" | "youtube";

type IconLink = {
  label: string;
  href: string;
  icon: IconName;
};

const iconLinks: IconLink[] = [
  {
    label: "Email Eddie Saunders",
    href: "mailto:eddie@eddiesaunders.com",
    icon: "email",
  },
  {
    label: "LinkedIn",
    href: "#",
    icon: "linkedin",
  },
  {
    label: "Facebook",
    href: "https://www.facebook.com/share/1CwtbEQvxp/?mibextid=wwXIfr",
    icon: "facebook",
  },
  {
    label: "YouTube",
    href: "https://www.youtube.com/@eddie_saunders",
    icon: "youtube",
  },
];

const renderIcon = (icon: IconName) => {
  const icons = {
    email: `
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M4 6h16v12H4V6Z" />
        <path d="m4 7 8 6 8-6" />
      </svg>
    `,
    linkedin: `
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6.5 10v8" />
        <path d="M6.5 6v.01" />
        <path d="M10.5 18v-8" />
        <path d="M10.5 13.5c0-2 1.2-3.5 3.3-3.5 2 0 3.2 1.3 3.2 3.7V18" />
        <path d="M4 3h16a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z" />
      </svg>
    `,
    facebook: `
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M14 8h2V4h-2c-3 0-5 2-5 5v2H7v4h2v6h4v-6h3l1-4h-4V9c0-.6.4-1 1-1Z" />
      </svg>
    `,
    youtube: `
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M4 8.5c.2-1.5 1.1-2.4 2.6-2.6C8 5.7 10 5.5 12 5.5s4 .2 5.4.4c1.5.2 2.4 1.1 2.6 2.6.2 1 .3 2.2.3 3.5s-.1 2.5-.3 3.5c-.2 1.5-1.1 2.4-2.6 2.6-1.4.2-3.4.4-5.4.4s-4-.2-5.4-.4c-1.5-.2-2.4-1.1-2.6-2.6-.2-1-.3-2.2-.3-3.5s.1-2.5.3-3.5Z" />
        <path d="m10 9 5 3-5 3V9Z" />
      </svg>
    `,
  };

  return icons[icon];
};
---

<footer class="site-footer">
  <div>
    <strong>Eddie Saunders</strong>
    <p>Code, craft, aerial notes, music, garden, and handmade creations.</p>
  </div>

  <nav class="footer-icon-links" aria-label="Contact and social links">
    {iconLinks.map((item) => (
      <a
        href={item.href}
        aria-label={item.label}
        title={item.label}
        target={item.href.startsWith("http") ? "_blank" : undefined}
        rel={item.href.startsWith("http") ? "noreferrer" : undefined}
        set:html={renderIcon(item.icon)}
      />
    ))}
  </nav>
</footer>
